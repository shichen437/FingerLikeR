{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FingerLike R",
  "version": "0.1.0",
  "identifier": "com.shichen437.fingerliker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FingerLike R",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "FingerLike R Development Root CA",
      "entitlements": null,
      "exceptionDomain": null,
      "hardenedRuntime": true
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyMjkyODI0MkE1NzMxNUMKUldSY01WY3FKQ2dwc2swNWtha0Vzc1JmY1VhYXdRdkY5Ykx4b3BYVGxadzFoQnpJRUxqb01MMk8K",
      "endpoints": [
        "https://github.com/shichen437/FingerLikeR/releases/latest/download/latest.json"
      ]
    }
  }
}
